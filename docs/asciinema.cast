[0.151, "o", "\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[133D\u001b[2K\u001b[1;38;2;232;162;23mSelect a script include to view:\u001b[0m\r\r\n\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B  ACEDemoDataUtils\u001b[38;2;136;136;136m - 5df6db91ebe4011090fa99602a52289e - Active\u001b[0m\r\r\n\u001b[38;2;232;162;23m> \u001b[0m\u001b[1mActionExecutionUtils\u001b[0m\u001b[38;2;136;136;136m - global - Active\u001b[0m\r\r\n\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[133D"]
[0.270, "o", "\u001b[2K\u001b[?25h\u001b[?1002l\u001b[?1003l\u001b[?1006l"]
[0.103, "o", "\r\n"]
[0.001, "o", "\u001b[1;38;2;232;162;23mActionExecutionUtils\u001b[0m\r\n\r\n  \u001b[38;2;136;136;136mSys ID:\u001b[0m 464ab848ff232210019cffffffffff07\r\n  \u001b[38;2;136;136;136mStatus:\u001b[0m Active\r\n  \u001b[38;2;136;136;136mScope:\u001b[0m global\r\n\r\n  \u001b[1;38;2;232;162;23mScript:\u001b[0m\r\n\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136mvar ActionExecutionUtils = Class.create();\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136mActionExecutionUtils.prototype = {\u001b[0m\r\n    \u001b[38;2;136;136;136m    initialize: function() {},\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n    \u001b[38;2;136;136;136m    /**\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * Evaluate a UI Action's server-side \"condition\" exactly as the platform would,\u001b[0m\r\n    \u001b[38;2;136;136;136m     * but callable from any scope. Returns a boolean.\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     *\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * @param {GlideRecord} currentGR - The target record against which to evaluate.\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * @param {String} uiActionSysId  - Sys ID of the sys_ui_action record whose condition to evaluate.\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * @returns {Boolean}\u001b[0m\r\n    \u001b[38;2;136;136;136m     */\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m    evaluateUIActionCondition: function(currentGR, uiActionSysId) {\u001b[0m\r\n    \u001b[38;2;136;136;136m        // Basic guards\u001b[0m\r\n    \u001b[38;2;136;136;136m        if (!currentGR || !currentGR.isValidRecord() || !uiActionSysId)\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            return false;\u001b[0m\r\n    \u001b[38;2;136;136;136m\u001b[0m\r\n    \u001b[38;2;136;136;136m        // 0) Ensure user can read the target record (don’t surface actions for records they can’t see)\u001b[0m\r\n    \u001b[38;2;136;136;136m        if (!currentGR.canRead())\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            return false;\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n    \u001b[38;2;136;136;136m        // 1) Load the UI Action\u001b[0m\r\n    \u001b[38;2;136;136;136m        var act = new GlideRecord('sys_ui_action');\u001b[0m\r\n    \u001b[38;2;136;136;136m        act.get(uiActionSysId);\u001b[0m\r\n    \u001b[38;2;136;136;136m        if (!act)\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            return false;\u001b[0m\r\n    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        // 2) Must be active\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        if (act.active.toString() !== 'true')\u001b[0m\r\n    \u001b[38;2;136;136;136m            return false;\u001b[0m\r\n    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        // 3) Role gate: the \"roles\" field is a comma-separated OR list\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        if (!this._userPassesRoleGate_(act))\u001b[0m\r\n    \u001b[38;2;136;136;136m            return false;\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        // 4) Table ancestry: the current record's table must be the same as or extend the UI action's table\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        var actionTable = (act.table + '').trim();\u001b[0m\r\n    \u001b[38;2;136;136;136m        if (actionTable && !this._tableAppliesToRecord_(actionTable, currentGR.getTableName()))\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            return false;\u001b[0m\r\n    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        // 5) Evaluate the \"condition\" in the **UI Action's scope** with the correct globals\u001b[0m\r\n    \u001b[38;2;136;136;136m        // DEF0776025: If there is no condition on the UI Action record, the expectation is that it evaluates to true\u001b[0m\r\n    \u001b[38;2;136;136;136m        // The role gate should already handle the case where the user is not logged in and the condition is empty,\u001b[0m\r\n    \u001b[38;2;136;136;136m        // so at this point, we can assume that the user is either (a) logged in or (b) not logged in but the condition\u001b[0m\r\n    \u001b[38;2;136;136;136m        // is not empty. For (a) we can return true when the condition is empty. For (b) condition cannot be empty so\u001b[0m\r\n    \u001b[38;2;136;136;136m        // we continue on to evaluate it.\u001b[0m\r\n    \u001b[38;2;136;136;136m        if (act.condition.isNil()) return true;\u001b[0m\r\n    \u001b[38;2;136;136;136m        var evaluator = new GlideScopedEvaluator();\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n    \u001b[38;2;136;136;136m        // Provide the same variables that a UI Action condition expects\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        evaluator.putVariable('current', currentGR); // required\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        // IMPORTANT: evaluate against the UI Action record, field = 'condition'\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        var result = evaluator.evaluateScript(act, 'condition');\u001b[0m\r\n    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        // UI Action conditions should yield a boolean; coerce safely\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        return ('true' === ('' + result)) || (result === true);\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m    },\u001b[0m\r\n    \u001b[38;2;136;136;136m    /**\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * Emulates the platform role check for UI Actions:\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     */\u001b[0m\r\n    \u001b[38;2;136;136;136m    _userPassesRoleGate_: function(act /* sys_ui_action GlideRecord */ ) {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        var actionRoleGr = new GlideRecord('sys_ui_action_role');\u001b[0m\r\n    \u001b[38;2;136;136;136m        actionRoleGr.addQuery('sys_ui_action', act.sys_id);\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        actionRoleGr.query();\u001b[0m\r\n    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        // if no role records exist for this action → allow access\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        if (!actionRoleGr.hasNext()) {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            var session = gs.getSession();\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            // if no role records exist for this action → allow access if the user is logged in\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            // if the user is not logged in, we still allow if condition is not empty\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            return session.isLoggedIn() || act.getValue('condition');\u001b[0m\r\n    \u001b[38;2;136;136;136m        }\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n    \u001b[38;2;136;136;136m        while (actionRoleGr.next()) {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            if (gs.hasRole(actionRoleGr.sys_user_role.name)) {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m                return true;\u001b[0m\r\n    \u001b[38;2;136;136;136m            }\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        }\u001b[0m\r\n    \u001b[38;2;136;136;136m        return false;\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m    },\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n    \u001b[38;2;136;136;136m    /**\u001b[0m"]
[0.000, "o", "\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * Verify that the current record's table is the same as, or extends from, the UI Action's table.\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * Uses TableUtils so we don't reinvent table hierarchy logic.\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     *\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * @param {String} actionTable - UI Action table (e.g., 'problem', 'task', etc.)\u001b[0m\r\n    \u001b[38;2;136;136;136m     * @param {String} recordTable - current.getTableName()\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     * @returns {Boolean}\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m     */\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m    _tableAppliesToRecord_: function(actionTable, recordTable) {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        if (!actionTable)\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            return true; // global actions (no table specified)\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        if (actionTable === recordTable)\u001b[0m\r\n    \u001b[38;2;136;136;136m            return true;\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        try {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            var tu = new TableUtils(actionTable);\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            var descendants = tu.getTables(); // includes the base table and all extended tables\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            // In some releases, getTables() returns an array with the base first—just check membership\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            for (var i = 0; i < descendants.length; i++) {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m                if (descendants[i] === recordTable)\u001b[0m\r\n    \u001b[38;2;136;136;136m                    return true;\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            }\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        } catch (e) {\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            // fail closed if hierarchy check cannot be determined\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m            return false;\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        }\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m        return false;\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m    },\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;136;136;136m\u001b[0m\r\n    \u001b[38;2;136;136;136m    type: 'ActionExecutionUtils'\u001b[0m\r\n    \u001b[38;2;136;136;136m};\u001b[0m\r\n"]
