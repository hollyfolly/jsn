[0.967, "o", "\r\n\u001b[1;38;2;232;162;23mFlow: Add Role to User Or Group\u001b[0m\r\n\r\n  Status: Active | Version: \u001b[38;2;136;136;136mUnset (Assumed V1)\u001b[0m\r\n  Sys ID: \u001b[38;2;136;136;136macc377bfc7010110408bc8d6f2c260b2\u001b[0m\r\n  Link: \u001b[38;2;0;170;255mhttps://dev373698.service-now.com/sys_hub_flow.do?sys_id=acc377bfc7010110408bc8d6f2c260b2\u001b[0m\r\n\r\n\u001b[1;38;2;0;255;0m▶ SUBFLOW\u001b[0m\r\n──────────────────────────────────────────────────\r\n  Inputs (6)\r\n    • \u001b[38;2;136;136;136madd role\u001b[0m: reference\u001b[38;2;136;136;136m\u001b[0m\r\n    • \u001b[38;2;136;136;136mis originating environment\u001b[0m: boolean\u001b[38;2;136;136;136m\u001b[0m\r\n    • \u001b[38;2;136;136;136mis group\u001b[0m: boolean\u001b[38;2;136;136;136m\u001b[0m\r\n    • \u001b[38;2;136;136;136muser id\u001b[0m: string\u001b[38;2;136;136;136m\u001b[0m\r\n    • \u001b[38;2;136;136;136mgroup id\u001b[0m: string\u001b[38;2;136;136;136m\u001b[0m\r\n    • \u001b[38;2;136;136;136mtarget environment\u001b[0m: reference\u001b[38;2;136;136;136m\u001b[0m\r\n\r\n  Outputs (2)\r\n    • \u001b[38;2;136;136;136merror message\u001b[0m: string\r\n    • \u001b[38;2;136;136;136mhas error\u001b[0m: boolean\r\n\r\n"]
[0.005, "o", "\r\n\u001b[1;38;2;255;170;0m⚡ FLOW STRUCTURE\u001b[0m\r\n──────────────────────────────────────────────────\r\n"]
[0.000, "o", "1. Top Level Try\r\n"]
[0.000, "o", "    2. If: is group\r\n"]
[0.000, "o", "        3. Look Up Record\r\n"]
[0.000, "o", "            \u001b[38;2;136;136;136mTable\u001b[0m: Group Role\r\n"]
[0.000, "o", "            \u001b[38;2;136;136;136mConditions\u001b[0m: group.sys_id={{subflow.group_id}}^role={{subflo...\r\n            \u001b[38;2;136;136;136mSort Type\u001b[0m: a to z\r\n"]
[0.000, "o", "            \u001b[38;2;136;136;136mIf multiple records are found action\u001b[0m: Return only the first record\r\n            \u001b[38;2;136;136;136mDon't fail on error\u001b[0m: true\r\n"]
[0.000, "o", "        4. If: No record found\r\n"]
[0.000, "o", "            5. Create Record\r\n"]
[0.000, "o", "                \u001b[38;2;136;136;136mFields\u001b[0m: group={{subflow.group_id}}^role={{subflow.add_r...\r\n"]
[0.000, "o", "            6. If: Record not created\r\n                7. Assign Subflow Outputs\r\n    8. Else\r\n"]
[0.000, "o", "        9. Look Up Record\r\n            \u001b[38;2;136;136;136mTable\u001b[0m: User Role\r\n"]
[0.000, "o", "            \u001b[38;2;136;136;136mConditions\u001b[0m: user.sys_id={{subflow.user_id}}^role={{subflow....\r\n"]
[0.000, "o", "            \u001b[38;2;136;136;136mSort Type\u001b[0m: a to z\r\n            \u001b[38;2;136;136;136mIf multiple records are found action\u001b[0m: Return only the first record\r\n"]
[0.000, "o", "            \u001b[38;2;136;136;136mDon't fail on error\u001b[0m: true\r\n"]
[0.000, "o", "        10. If: No record found\r\n"]
[0.000, "o", "            11. Create Record\r\n"]
[0.000, "o", "                \u001b[38;2;136;136;136mFields\u001b[0m: user={{subflow.user_id}}^role={{subflow.add_role}}\r\n            12. If: Record not created\r\n                13. Assign Subflow Outputs\r\n14. Top Level Catch\r\n    15. Assign Subflow Outputs"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\n"]
