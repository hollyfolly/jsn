[1.176, "o", "\u001b[3;90m# Use `jsn updateset use` or `jsn scope use` to change scope/updateset\u001b[0m\r\n\u001b[1;90mPROFILE USER   [SCOPE]  UPDATE SET\u001b[0m\r\n\u001b]8;;https://dev373698.service-now.com\u001b\\pdi    \u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_user_list.do?sysparm_query=sys_id=6816f79cc0a8016401c5a33be04be441\u001b\\System\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_scope.do?sysparm_query=scope=global\u001b\\[global]\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_update_set.do?sys_id=7dba58ecf54403100a22c0b3dfa151af\u001b\\Default\u001b]8;;\u001b\\\r\n"]
[0.289, "o", "\r\n\u001b[1;38;2;232;162;23mAIAB Chat (aiab_chat)\u001b[0m\r\n\r\n\u001b[1;38;2;102;102;102m─ HTML Template ─\u001b[0m\r\n"]
[0.001, "o", "\u001b[38;2;166;226;46m<div class=\"aiab-chat-container\" ng-if=\"data.chatEnabled\" ng-class=\"{'aiab-chat-wide': c.isWide, 'aiab-chat-snoozed': c.isSnoozed}\">\u001b[0m                      \r\n\u001b[38;2;166;226;46m  <!-- Floating Chat Button -->\u001b[0m                                                                                                                           \r\n\u001b[38;2;166;226;46m  <button class=\"aiab-chat-button\" ng-click=\"c.toggleChat()\" ng-hide=\"c.isOpen || c.isSnoozed\" title=\"Chat with AI Assistant\">\u001b[0m                            \r\n\u001b[38;2;166;226;46m    <span class=\"aiab-chat-button-icon\">💬</span>\u001b[0m                                                                                                         \r\n\u001b[38;2;166;226;46m    <span class=\"aiab-chat-button-text\">Chat</span>\u001b[0m                                                                                                       \r\n\u001b[38;2;166;226;46m  </button>\u001b[0m                                                                                                                                               \r\n\u001b[38;2;166;226;46m\u001b[0m                                                                                                                                                          \r\n\u001b[38;2;166;226;46m  <!-- Snoozed indicator (small button to restore) -->\u001b[0m                                                                                                    \r\n\u001b[38;2;166;226;46m  <button class=\"aiab-chat-snoozed-btn\" ng-show=\"c.isSnoozed\" ng-click=\"c.unsnooze()\" title=\"Show chat\">\u001b[0m                                                  \r\n\u001b[38;2;166;226;46m    <span>💬</span>\u001b[0m                                                                                                                                       \r\n\u001b[38;2;166;226;46m  </button>\u001b[0m                                                                                                                                               \r\n\u001b[38;2;166;226;46m\u001b[0m                                                                                                                                                          \r\n\u001b[38;2;166;226;46m  <!-- Chat Dialog -->\u001b[0m                                                                                                                                    \r\n\u001b[38;2;166;226;46m  <div class=\"aiab-chat-dialog\" ng-show=\"c.isOpen\">\u001b[0m                                                                                                       \r\n\u001b[38;2;166;226;46m    <!-- Header -->\u001b[0m                                                                                                                                       \r\n\u001b[38;2;166;226;46m    <div class=\"aiab-chat-header\">\u001b[0m                                                                                                                        \r\n\u001b[38;2;166;226;46m      <h5 class=\"aiab-chat-title\">{{c.options.title || 'AI Assistant'}}</h5>\u001b[0m                                                                              \r\n\u001b[38;2;166;226;46m      <div class=\"aiab-chat-header-buttons\">\u001b[0m                                                                                                              \r\n\u001b[38;2;166;226;46m        <!-- History button -->\u001b[0m                                                                                                                           \r\n\u001b[38;2;166;226;46m        <button class=\"aiab-chat-btn\" ng-if=\"c.previousChats.length > 0\" ng-click=\"c.showHistoryMenu = !c.showHistoryMenu\" title=\"Previous conversations\">\u001b[0m\r\n\u001b[38;2;166;226;46m          <span>📜</span>\u001b[0m                                                                                                                                 \r\n\u001b[38;2;166;226;46m        </button>\u001b[0m                                                                                                                                         \r\n\u001b[38;2;166;226;46m        <!-- New chat button -->\u001b[0m                                                                                                                       "]
[0.000, "o", "   \r\n\u001b[38;2;166;226;46m        <button class=\"aiab-chat-btn\" ng-if=\"c.isViewingHistory\" ng-click=\"c.startNewChat()\" title=\"New conversation\">\u001b[0m                                    \r\n\u001b[38;2;166;226;46m          <span>➕</span>\u001b[0m                                                                                                                                 \r\n\u001b[38;2;166;226;46m        </button>\u001b[0m                                                                                                                                         \r\n\u001b[38;2;166;226;46m        <!-- Enlarge/shrink button -->\u001b[0m                                                                                                                    \r\n\u001b[38;2;166;226;46m        <button class=\"aiab-chat-btn\" ng-click=\"c.toggleWide()\" title=\"{{c.isWide ? 'Shrink' : 'Enlarge'}}\">\u001b[0m                                              \r\n\u001b[38;2;166;226;46m          <span ng-hide=\"c.isWide\">⤢</span>\u001b[0m                                                                                                               \r\n\u001b[38;2;166;226;46m          <span ng-show=\"c.isWide\">⤡</span>\u001b[0m                                                                                                               \r\n\u001b[38;2;166;226;46m        </button>\u001b[0m                                                                                                                                         \r\n\u001b[38;2;166;226;46m        <!-- Snooze button -->\u001b[0m                                                                                                                            \r\n\u001b[38;2;166;226;46m        <button class=\"aiab-chat-btn\" ng-click=\"c.snooze()\" title=\"Hide for now\">\u001b[0m                                                                         \r\n\u001b[38;2;166;226;46m          <span>🔕</span>\u001b[0m                                                                                                                                 \r\n\u001b[38;2;166;226;46m        </button>\u001b[0m                                                                                                                                         \r\n\u001b[38;2;166;226;46m        <!-- Close button -->\u001b[0m                                                                                                                             \r\n\u001b[38;2;166;226;46m        <button class=\"aiab-chat-btn aiab-chat-close\" ng-click=\"c.toggleChat()\" title=\"Close\">\u001b[0m                                                            \r\n\u001b[38;2;166;226;46m          <span>×</span>\u001b[0m                                                                                                                                  \r\n\u001b[38;2;166;226;46m        </button>\u001b[0m                                                                                                                                         \r\n\u001b[38;2;166;226;46m      </div>\u001b[0m                                                                                                                                              \r\n\u001b[38;2;166;226;46m      <!-- History dropdown menu -->\u001b[0m                                                                                                                      \r\n\u001b[38;2;166;226;46m      <div class=\"aiab-history-menu\" ng-show=\"c.showHistoryMenu\">\u001b[0m                                                                                         \r\n\u001b[38;2;166;226;46m        <div class=\"aiab-history-header\">Previous Conversations</div>\u001b[0m                                                                                     \r\n\u001b[38;2;166;226;46m        <button ng-repeat=\"chat in c.previousChats\" ng-click=\"c.loadConversation(chat.sys_id)\" title=\"{{chat.created}}\">\u001b[0m                                  \r\n\u001b[38;2;166;226;46m          <span class=\"aiab-history-preview\">{{chat.preview}}</span>\u001b[0m                                                                                      \r\n\u001b[38;2;166;226;46m          <span class=\"aiab-history-date\">{{chat.created}}</span>\u001b[0m                                                                                         \r\n\u001b[38;2;166;226;46m        </button>\u001b[0m                                                                                                                                         \r\n\u001b[38;2;166;226;46m      </div>\u001b[0m                                                                                                                                              \r\n\u001b[38;2;166;226;46m    </div>\u001b[0m                                                                                                                                                \r\n\u001b[38;2;166;226;46m\u001b[0m                                                                                                                                                          \r\n\u001b[38;2;166;226;46m    <!-- Record context indicator -->\u001b[0m                                                                                                                     \r\n\u001b[38;2;166;226;46m    <div class=\"aiab-chat-context\" ng-if=\"c.recordTable\">\u001b[0m                                                                                                 \r\n\u001b[38;2;166;226;46m      <span class=\"aiab-chat-context-icon\">📋</span>\u001b[0m                                                                                                      \r\n\u001b[38;2;166;226;46m      <span class=\"aiab-chat-context-text\">{{c.recordTable}}: {{c.recordDisplay || c.recordSysId}}</span>\u001b[0m                                                 \r\n\u001b[38;2;166;226;46m      <span class=\"aiab-chat-context-badge\" ng-if=\"c.isViewingHistory\">(viewing history)</span>\u001b[0m                                                           \r\n\u001b[38;2;166;226;46m    </div>\u001b[0m                                                                                                                                                \r\n\u001b[38;2;166;226;46m\u001b[0m                                                                                                                                                          \r\n\u001b[38;2;166;226;46m    <!-- Messages -->\u001b[0m                                                                                                                                     \r\n\u001b[38;2;166;226;46m    <div class=\"aiab-chat-messages\" id=\"aiab-chat-messages\">\u001b[0m                                                                                              \r\n\u001b[38;2;166;226;46m      <div ng-repeat=\"msg in c.messages track by $index\" \u001b[0m                                                                                                 \r\n\u001b[38;2;166;226;46m           class=\"aiab-chat-message\" \u001b[0m                                                                                                                     \r\n\u001b[38;2;166;226;46m           ng-class=\"{'aiab-chat-message--user': msg.role === 'user', 'aiab-chat-message--assistant': msg.role === 'assistant'}\">\u001b[0m                         \r\n\u001b[38;2;166;226;46m        <div class=\"aiab-chat-bubble\" ng-bind-html=\"c.renderMessage(msg.content)\"></div>\u001b[0m                                                                  \r\n\u001b[38;2;166;226;46m      </div>\u001b[0m                                                                                                                                              \r\n\u001b[38;2;166;226;46m      <div ng-if=\"c.isLoading\" class=\"aiab-chat-message aiab-chat-message--assistant\">\u001b[0m                                                                    \r\n\u001b[38;2;166;226;46m        <div class=\"aiab-chat-bubble aiab-chat-loading\">\u001b[0m                                                                                                  \r\n\u001b[38;2;166;226;46m          <span class=\"aiab-chat-dot\"></span>\u001b[0m                                                                                                             \r\n\u001b[38;2;166;226;46m          <span class=\"aiab-chat-dot\"></span>\u001b[0m                                                                                                             \r\n\u001b[38;2;166;226;46m          <span class=\"aiab-chat-dot\"></span>\u001b[0m                                                                                                             \r\n\u001b[38;2;166;226;46m        </div>\u001b[0m                                                                                                                                            \r\n\u001b[38;2;166;226;46m      </div>\u001b[0m                                                                                                                                              \r\n\u001b[38;2;166;226;46m    </div>\u001b[0m                                                                                                                                                \r\n\u001b[38;2;166;226;46m\u001b[0m                                                                                                                                                          \r\n\u001b[38;2;166;226;46m    <!-- Input Area -->\u001b[0m                                                                                                                                   \r\n\u001b[38;2;166;226;46m    <div class=\"aiab-chat-input-area\">\u001b[0m                                                                                                                    \r\n\u001b[38;2;166;226;46m      <input type=\"text\" \u001b[0m                                                                                                                                 \r\n\u001b[38;2;166;226;46m             class=\"aiab-chat-input\" \u001b[0m                                                                                                                     \r\n\u001b[38;2;166;226;46m             ng-model=\"c.userInput\" \u001b[0m                                                                                                                      \r\n\u001b[38;2;166;226;46m             ng-keypress=\"c.handleKeypress($event)\"\u001b[0m                                                                                                       \r\n\u001b[38;2;166;226;46m             placeholder=\"{{c.isViewingHistory ? 'Continue this conversation...' : (c.options.placeholder || 'Type a message...')}}\"\u001b[0m                      \r\n\u001b[38;2;166;226;46m             ng-disabled=\"c.isLoading\" />\u001b[0m                                                                                                                 \r\n\u001b[38;2;166;226;46m      <button class=\"aiab-chat-send\" \u001b[0m                                                                                                                     \r\n\u001b[38;2;166;226;46m              ng-click=\"c.sendMessage()\" \u001b[0m                                                                                                                 \r\n\u001b[38;2;166;226;46m              ng-hide=\"c.isLoading\"\u001b[0m                                                                                                                       \r\n\u001b[38;2;166;226;46m              ng-disabled=\"!c.userInput\">\u001b[0m                                                                                                                 \r\n\u001b[38;2;166;226;46m        Send\u001b[0m                                                                                                                                              \r\n\u001b[38;2;166;226;46m      </button>\u001b[0m                                                                                                                                           \r\n\u001b[38;2;166;226;46m      <button class=\"aiab-chat-stop\" \u001b[0m                                                                                                                     \r\n\u001b[38;2;166;226;46m              ng-click=\"c.stopGeneration()\" \u001b[0m                                                                                                              \r\n\u001b[38;2;166;226;46m              ng-show=\"c.isLoading\">\u001b[0m                                                                                                                      \r\n\u001b[38;2;166;226;46m        Stop\u001b[0m                                                                                                                                              \r\n\u001b[38;2;166;226;46m      </button>\u001b[0m                                                                                                                                           \r\n\u001b[38;2;166;226;46m    </div>\u001b[0m                                                                                                                                                \r\n\u001b[38;2;166;226;46m  </div>\u001b[0m                                                                                                                                                  \r\n\u001b[38;2;166;226;46m</div>\u001b[0m                                                                                                                                                    \r\n"]
