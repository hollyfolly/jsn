[0.000, "o", "  | setDisabled                   | [Desktop](#desktop-setdisabled)                   | [Mobile](#mobile-setdisabled)         | No         |\r\n  | setDisabledControl            | [Desktop](#desktop-setdisabledcontrol)            |                                       | No         |\r\n  | setDisplay                    | [Desktop](#desktop-setdisplay)                    |                                       | No         |\r\n  | setFieldPlaceholder           |                                                   | [Mobile](#mobile-setfieldplaceholder) | No         |\r\n  | setLabel                      |                                                   | [Mobile](#mobile-setlabel)            | Mobile     |\r\n  | setLabelOf                    | [Desktop](#desktop-setlabelof)                    | [Mobile](#mobile-setlabelof)          | Desktop    |\r\n  | setLiveUpdating               | [Desktop](#desktop-setliveupdating)               |                                       | No         |\r\n  | setMandatory                  | [Desktop](#desktop-setmandatory)                  | [Mobile](#mobile-setmandatory)        | Desktop    |\r\n  | setMandatoryOnlyIfModified    | [Desktop](#desktop-setmandatoryonlyifmodified)    |                                       | No         |\r\n  | setReadOnly                   | [Desktop](#desktop-setreadonly)                   | [Mobile](#mobile-setreadonly)         | Desktop    |\r\n  | setReadonly                   | [Desktop](#desktop-setreadonly)                   | [Mobile](#mobile-setreadonly)         | No         |\r\n  | setRequiredChecked            | [Desktop](#desktop-setrequiredchecked)            |                                       | No         |\r\n  | setScope                      | [Desktop](#desktop-setscope)                      |                                       | No         |\r\n  | setSectionDisplay             | [Desktop](#desktop-setsectiondisplay)             | [Mobile](#mobile-setsectiondisplay)   | No         |\r\n  | setSensitiveDisplayValue      | [Desktop](#desktop-setsensitivedisplayvalue)      |                                       | No         |\r\n  | setStreamJournalFieldsDisplay | [Desktop](#desktop-setstreamjournalfieldsdisplay) |                                       | No         |\r\n  | setTemplateValue              | [Desktop](#desktop-settemplatevalue)              |                                       | No         |\r\n  | setUserDisplay                | [Desktop](#desktop-setuserdisplay)                |                                       | No         |\r\n  | setValidation                 | [Desktop](#desktop-setvalidation)                 |                                       | No         |\r\n  | setValue                      | [Desktop](#desktop-setvalue)                      | [Mobile](#mobile-setvalue)            | Desktop    |\r\n  | setVariablesReadOnly          | [Desktop](#desktop-setvariablesreadonly)          |                                       | No         |\r\n  | setVisible                    | [Desktop](#desktop-setvisible)                    | [Mobile](#mobile-setvisible)          | Desktop    |\r\n  | showErrorBox                  | [Desktop](#desktop-showerrorbox)                  | [Mobile](#mobile-showerrorbox)        | Desktop    |\r\n  | showFieldMsg                  | [Desktop](#desktop-showfieldmsg)                  | [Mobile](#mobile-showfieldmsg)        | Desktop    |\r\n  | showRelatedList               | [Desktop](#desktop-showrelatedlist)               | [Mobile](#mobile-showrelatedlist)     | Desktop    |\r\n  | showRelatedLists              | [Desktop](#desktop-showrelatedlists)              | [Mobile](#mobile-showrelatedlists)    | Desktop    |\r\n  | submit                        | [Desktop](#desktop-submit)                        | [Mobile](#mobile-submit)              | Desktop    |\r\n  | validate                      | [Desktop](#desktop-validate)                      |                                       | No         |\r\n  These methods I've found in the script that dictates it's available on\r\n"]
[0.000, "o", "  the portal/mobile clients.\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile addDecoration\u001b[0m\r\n\r\n"]
[0.000, "o", "  Adds an icon on a field's label. This method is available starting with\r\n"]
[0.000, "o", "  the Fuji release. Icons available\r\n"]
[0.000, "o", "  [here](https://hi.service-now.com/styles/retina_icons/retina_icons.html)\r\n"]
[0.000, "o", "  Adding the same item twice is prevented; however, you can add the same\r\n  icon with a different title.\r\n"]
[0.000, "o", "  g_form.addDecoration('caller_id', 'icon-star', 'VIP');\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getLabel\u001b[0m\r\n\r\n  if (g_user.hasRole('itil')) {\r\n  // getLabel returns the label for the field listed\r\n  // I'd suggest using getLabelOf as it's supported\r\n"]
[0.000, "o", "  // both on desktop and on mobile / sp\r\n  var oldLabel = g_form.getLabel('comments');\r\n"]
[0.000, "o", "  g_form.setLabel('comments', oldLabel + ' (Customer visible)');\r\n"]
[0.000, "o", "  }\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile hasField\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  // returns true if form has 'assignment group';\r\n"]
[0.000, "o", "  g_form.hasField('assignment_group');\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile removeDecoration\u001b[0m\r\n"]
[0.000, "o", "\r\n  // this removes a decoration\r\n  g_form.removeDecoration('caller_id', 'icon-star', 'VIP');\r\n"]
[0.000, "o", "\r\n\u001b[1mMobile setLabel\u001b[0m\r\n\r\n"]
[0.000, "o", "  if (g_user.hasRole('itil')) {\r\n  var oldLabel = g_form.getLabel('comments');\r\n  g_form.setLabel('comments', oldLabel + ' (Customer visible)');\r\n"]
[0.000, "o", "  }\r\n"]
[0.001, "o", "\r\n\u001b[1mMobile addErrorMessage\u001b[0m\r\n\r\n  Displays an error message at the top of the form\r\n  g_form.addErrorMessage('ERROR!');\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile addInfoMessage\u001b[0m\r\n\r\n  Displays an informational message at the top of the form\r\n  g_form.addInfoMessage('The top five fields in this form are mandatory');\r\n\r\n\u001b[1mMobile addOption\u001b[0m\r\n\r\n"]
[0.000, "o", "  Adds a choice to a choice list field If the index is not specified, the\r\n  choice is added to the end of the list.\r\n  Optional: Use the index field to specify a particular place in the list\r\n  g_form.addOption('priority', '6', '6 - Really Low');\r\n"]
[0.000, "o", "  g_form.addOption('priority', '2.5', '2.5 - Moderately High', 3);\r\n\r\n\u001b[1mMobile clearMessages\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  Removes all informational and error messages from the top of the form.\r\n"]
[0.000, "o", "  Removes informational and error messages added with\r\n  `g_form.addInfoMessage()` and `g_form.addErrorMessage()`.\r\n"]
[0.000, "o", "  g_form.clearMessages();\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile clearOptions\u001b[0m\r\n\r\n"]
[0.000, "o", "  Removes all options from a choice list\r\n"]
[0.000, "o", "  g_form.clearOptions('priority');\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile clearValue\u001b[0m\r\n\r\n  Removes any value(s) from the specified field\r\n"]
[0.000, "o", "  g_form.clearValue('short_desciption');\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getActionName\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the most recent action name or, for a client script, the sys\\_id\r\n  of the UI Action clicked Note: not available to Wizard Client Scripts\r\n  function onSubmit() {\r\n  var action = g_form.getActionName();"]
[0.000, "o", "\r\n  console.log('You pressed ' + action);\r\n  }"]
[0.000, "o", "\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getBooleanValue\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns false if the field's value is false or undefined, otherwise true\r\n  is returned. Useful with checkbox fields Returns true when the checkbox\r\n  is checked\r\n  // Returns false if the field value is false or undefined;\r\n"]
[0.000, "o", "  // otherwise returns true.\r\n  var active = g_form.getBooleanValue('active');\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getDecimalValue\u001b[0m\r\n\r\n  function onChange(control, oldValue, newValue, isLoading) {\r\n"]
[0.000, "o", "  console.log(g_form.getDecimalValue('percent_complete'));"]
[0.000, "o", "\r\n"]
[0.000, "o", "  }\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getDisplayValue\u001b[0m\r\n\r\n"]
[0.000, "o", "  g_form.getDisplayValue();//returns record displayvalue, not field displayvalue\r\n"]
[0.000, "o", "  g_form.getDispalyValue('caller_id');//returns record displayvalue, not field displayvalue\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getEncodedRecord\u001b[0m\r\n\r\n  // returns '' or _options.encodedRecord normally that's null\r\n  // I don't see when that would be set to something else.  Doesn't\r\n"]
[0.000, "o", "  // seem to work on catalog items, or on form's in service portal.\r\n  g_form.getEncodedRecord();\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mMobile getField\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  This is undocumented and I havent been able to find or test this yet,\r\n  however it comes from this source;\r\n"]
[0.000, "o", "  <https://community.servicenow.com/community?id=community_question&sys_id=2a151ed0db262b4011762183ca961957$answer_fe97e3bfdb4ef304f21f5583ca961964#answer_fe97e3bfdb4ef304f21f5583ca961964>\r\n  // this code is to limit a multirowvariableset to two rows\r\n  function onLoad() {\r\n"]
[0.000, "o", "  var field = g_form.getField(\"uk_billing_invoice_details_new\");\r\n  if (field != null) {\r\n  field.max_rows_size = 2;\r\n"]
[0.000, "o", "  }\r\n  }"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mMobile getFieldNames\u001b[0m\r\n\r\n  g_form.getFieldNames();\r\n"]
[0.000, "o", "  // returns array of strings of fields (and derived fields)\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getIntValue\u001b[0m\r\n\r\n"]
[0.000, "o", "  function onChange(control, oldValue, newValue, isLoading) {\r\n"]
[0.000, "o", "  console.log(g_form.getIntValue('state'));\r\n  }\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getLabelOf\u001b[0m\r\n\r\n  if (g_user.hasRole('itil')) {\r\n"]
[0.000, "o", "  var oldLabel = g_form.getLabelOf('comments');\r\n  g_form.setLabelOf('comments', oldLabel + ' (Customer visible)');\r\n  }\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mMobile getReference\u001b[0m\r\n\r\n  function onChange(control, oldValue, newValue, isLoading) {\r\n"]
[0.000, "o", "  var caller = g_form.getReference('caller_id', function(reference){\r\n  if (reference.vip == 'true') {\r\n  console.log('Caller is a VIP!');\r\n"]
[0.000, "o", "  }\r\n  });"]
[0.000, "o", "\r\n  }\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getRelatedListNames\u001b[0m\r\n\r\n"]
[0.000, "o", "  // Returns all related table.refernce related lists\r\n"]
[0.000, "o", "  // This is in the form of an array of strings.\r\n  g_form.getRelatedListNames();\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getSectionNames\u001b[0m\r\n\r\n  // Returns all section names, whether visible or not.\r\n  // This is in the form of an array of strings.\r\n"]
[0.000, "o", "  g_form.getSectionNames();\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getSysId\u001b[0m\r\n\r\n  function onLoad() {\r\n  var incSysid = g_form.getSysId();\r\n  console.log(incSysid);\r\n"]
[0.000, "o", "  }\r\n\r\n"]
[0.000, "o", "\u001b[1mMobile getTableName\u001b[0m\r\n\r\n  function onLoad() {\r\n  if (g_form.isNewRecord() {\r\n"]
[0.000, "o", "  var tableName = g_form.getTableName(); //Get the table name\r\n  }\r\n"]
[0.000, "o", "  }\r\n"]
