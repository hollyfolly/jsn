[0.000, "o", "\u001b[1mDesktop\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop addDecoration\u001b[0m\r\n\r\n"]
[0.000, "o", "  Adds an icon on a field's label. This method is available starting with\r\n  the Fuji release. Icons available\r\n  [here](https://hi.service-now.com/styles/retina_icons/retina_icons.html)\r\n"]
[0.000, "o", "  Adding the same item twice is prevented; however, you can add the same\r\n"]
[0.000, "o", "  icon with a different title.\r\n  Note: This method is not supported by Service Catalog.\r\n  g_form.addDecoration('caller_id', 'icon-star', 'preferred member');\r\n"]
[0.000, "o", "  g_form.addDecoration('caller_id', 'icon-star', 'Mark as Favorite', 'color-green');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop addErrorMessage\u001b[0m\r\n\r\n  Displays the error message at the top of the form.\r\n  g_form.addErrorMessage('This is an error');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop addInfoMessage\u001b[0m\r\n\r\n  Displays an informational message at the top of the form\r\n"]
[0.000, "o", "  g_form.addInfoMessage('The top five fields in this form are mandatory');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop addOption\u001b[0m\r\n\r\n  Adds a choice to a choice list field If the index is not specified, the\r\n"]
[0.000, "o", "  choice is added to the end of the list.\r\n"]
[0.000, "o", "  Optional: Use the index field to specify a particular place in the list\r\n"]
[0.000, "o", "  g_form.addOption('priority', '6', '6 - Really Low');\r\n  g_form.addOption('priority', '2.5', '2.5 - Moderately High', 3)\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop clearMessages\u001b[0m\r\n\r\n  Removes all informational and error messages from the top of the form.\r\n"]
[0.000, "o", "  Removes informational and error messages added with\r\n"]
[0.000, "o", "  `g_form.addInfoMessage()` and `g_form.addErrorMessage()`.\r\n  g_form.clearMessages();\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop clearOptions\u001b[0m\r\n\r\n  Removes all options from a choice list\r\n"]
[0.000, "o", "  g_form.clearOptions('priority');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop clearValue\u001b[0m\r\n\r\n  Removes any value(s) from the specified field\r\n"]
[0.000, "o", "  g_form.clearValue('short_desciption');\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mDesktop disableAttachments\u001b[0m\r\n\r\n  Prevents new file attachments from being added Hides the paperclip icon.\r\n"]
[0.000, "o", "  See also: enableAttachments()\r\n  g_form.disableAttachments();\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mDesktop enableAttachments\u001b[0m\r\n\r\n  Allows new file attachments to be added Shows the paperclip icon. See\r\n  also: disableAttachments()\r\n"]
[0.000, "o", "  g_form.enableAttachments();\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop flash\u001b[0m\r\n\r\n  Flashes the specified color the specified number of times in the field.\r\n"]
[0.000, "o", "  Used to draw attention to a particular field.\r\n  This method is not supported by Service Catalog.\r\n  This method is not available on the mobile platform. If this method is\r\n  run on a mobile platform, no action occurs.\r\n"]
[0.000, "o", "  The third parameter operates with the following inputs;\r\n  | Input | Action         |\r\n  | ----- | -------------- |\r\n"]
[0.000, "o", "  | 2     | 1 second flash |\r\n  | 0     | 2 second flash |\r\n  | -2    | 3 second flash |\r\n  | -4    | 4 second flash |\r\n"]
[0.000, "o", "  g_form.flash('incident.caller_id','red',2);\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getActionName\u001b[0m\r\n\r\n  Returns the most recent action name or, for a client script, the sys\\_id\r\n  of the UI Action clicked Note: not available to Wizard Client Scripts\r\n"]
[0.000, "o", "  function onSubmit() {\r\n  var action = g_form.getActionName();\r\n"]
[0.000, "o", "  console.log('You pressed ' + action);\r\n"]
[0.000, "o", "  }\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getBooleanValue\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns false if the field's value is false or undefined, otherwise true\r\n  is returned. Useful with checkbox fields Returns true when the checkbox\r\n"]
[0.000, "o", "  is checked\r\n"]
[0.000, "o", "  // Returns false if the field value is false or undefined;\r\n"]
[0.000, "o", "  // otherwise returns true.\r\n  var active = g_form.getBooleanValue('active');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getControl\u001b[0m\r\n\r\n  Returns the HTML element for the specified field Compound fields may\r\n"]
[0.000, "o", "  contain several HTML elements. Generally not necessary as there are\r\n  built-in methods that use the fields on the form\r\n  g_form.getControl('caller_id');//returns html element for field.\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getDecimalValue\u001b[0m\r\n\r\n  Returns the decimal value of the specified field\r\n"]
[0.000, "o", "  g_form.getDecimalValue('percent_complete')\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getElement\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the HTML element for the field specified via the ID Compound\r\n"]
[0.000, "o", "  fields may contain several HTML elements. Generally not necessary as\r\n  there are built-in methods that use the fields on the form\r\n  g_form.getElement('caller_id');//returns html element for field.\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mDesktop getFormElement\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the HTML element for the form.\r\n  This method is not available in mobile scripts or Service Portal\r\n  scripts.\r\n"]
[0.000, "o", "  //Can't test, not available on the global scope in the console.\r\n  g_form.getFormElement();\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mDesktop getHelpTextControl\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the HTML element of the help text for the specified field.\r\n"]
[0.000, "o", "  This method is applicable to service catalog variables only.\r\n"]
[0.000, "o", "  //Can't test, not available on the global scope in the console.\r\n  g_form.getHelpTextControl('myspecialvariable');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getIntValue\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the value of the specified field as an integer An empty value\r\n  returns 0\r\n"]
[0.000, "o", "  g_form.getIntValue('priority');//returns 4 as a interger\r\n"]
[0.000, "o", "  g_form.getValue('priority');//returns 4 as a string\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getLabelOf\u001b[0m\r\n\r\n"]
[0.000, "o", "  Gets the plain text value of the field label. This method is available\r\n  starting with the Fuji release\r\n"]
[0.000, "o", "  g_form.getLabelOf('caller_id');// returns the displayed label for field\r\n\r\n\u001b[1mDesktop getOption\u001b[0m\r\n"]
[0.000, "o", "\r\n  Returns the `<option>` element for a select box named fieldName and\r\n  where choiceValue matches the option value Returns null if the field is\r\n"]
[0.000, "o", "  not found or the option is not found\r\n"]
[0.000, "o", "  g_form.getOption('priority', 1);// returns html element for <option>\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getReference\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the GlideRecord for a specified field getReference() accepts a\r\n  second parameter, a callback function Warning: This requires a call to\r\n  the server so using this function will require additional time and may\r\n  introduce latency to your page\r\n"]
[0.000, "o", "  function onChange(control, oldValue, newValue, isLoading) {\r\n  var caller = g_form.getReference('caller_id', function(reference){\r\n"]
[0.000, "o", "  if (reference.vip == 'true') {\r\n  console.log('Caller is a VIP!');\r\n"]
[0.000, "o", "  }\r\n  });\r\n  }\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getSectionNames\u001b[0m\r\n\r\n  Returns all section names, whether visible or not, in an array This\r\n  method is available starting with the Fuji release\r\n"]
[0.000, "o", "  g_form.getSectionNames();//returns array of strings;\r\n"]
[0.000, "o", "  // e.g. [\"notes\", \"related_records\", \"closure_information\"]\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mDesktop getSections\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the elements for the form's sections in an array\r\n  g_form.getSectionNames();//returns array of elements;\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getTableName\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the name of the table this record belongs to\r\n  g_form.getTableName();//returns string of table, e.g. \"incident\"\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop getUniqueValue\u001b[0m\r\n\r\n  Returns the sys\\_id of the record displayed in the form\r\n  g_form.getUniqueValue(); // returns sys_id of recrod\r\n"]
[0.000, "o", "\r\n\u001b[1mDesktop getValue\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns the value of the specified field\r\n"]
[0.000, "o", "  g_form.getValue('caller_id');// returns value of field\r\n"]
[0.000, "o", "\r\n\u001b[1mDesktop hideAllFieldMsgs\u001b[0m\r\n\r\n"]
[0.001, "o", "  Hides all field messages. `<type>` paramter is optional\r\n  g_form.hideAllFieldMsgs('info');\r\n  g_form.hideAllFieldMsgs();\r\n"]
[0.000, "o", "\r\n\u001b[1mDesktop hideErrorBox\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  Hides the error message placed by showErrorBox()\r\n  Whenever possible, use hideFieldMsg() rather than this method whenever\r\n  possible.\r\n"]
[0.000, "o", "  g_form.hideErrorBox('caller_id');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop hideFieldMsg\u001b[0m\r\n\r\n  Hides the message placed by showFieldMsg();\r\n  g_form.hideFieldMsg('caller_id');\r\n"]
[0.000, "o", "  var clearAll = true;\r\n  g_form.hideFieldMsg('caller_id', clearAll);\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop hideRelatedList\u001b[0m\r\n\r\n"]
[0.000, "o", "  Hides the specified related list on the form\r\n  function onChange(control, oldValue, newValue, isLoading, isTemplate) {\r\n"]
[0.000, "o", "  if (isLoading || newValue === '') {\r\n  return;\r\n  }\r\n"]
[0.000, "o", "  if(newValue == 'hide'){\r\n  g_form.hideRelatedList('sc_request');\r\n  } else if(newValue == 'show') {\r\n"]
[0.000, "o", "  g_form.showRelatedList('sc_request');\r\n  } else if(newValue == 'hide all'){\r\n"]
[0.000, "o", "  g_form.hideRelatedLists();"]
[0.000, "o", "\r\n"]
[0.000, "o", "  } else if(newValue == 'show all'){\r\n"]
[0.000, "o", "  g_form.showRelatedLists();\r\n  }\r\n  }\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop hideRelatedLists\u001b[0m\r\n\r\n"]
[0.000, "o", "  Hides all related lists on the form\r\n  function onChange(control, oldValue, newValue, isLoading, isTemplate) {\r\n"]
[0.000, "o", "  if (isLoading || newValue === '') {\r\n  return;\r\n  }\r\n  if(newValue == 'hide'){\r\n"]
[0.000, "o", "  g_form.hideRelatedList('sc_request');\r\n"]
[0.000, "o", "  } else if(newValue == 'show') {\r\n  g_form.showRelatedList('sc_request');\r\n  } else if(newValue == 'hide all'){\r\n"]
[0.000, "o", "  g_form.hideRelatedLists();"]
[0.000, "o", "\r\n"]
[0.000, "o", "  } else if(newValue == 'show all'){\r\n  g_form.showRelatedLists();\r\n  }\r\n"]
[0.000, "o", "  }\r\n"]
[0.000, "o", "\r\n\u001b[1mDesktop isLiveUpdating\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mDesktop isMandatory\u001b[0m\r\n\r\n"]
[0.000, "o", "  Returns true while a live update is being done on the record the form is\r\n  showing.\r\n  This can be used in an onChange() client script to determine if a change\r\n"]
[0.000, "o", "  to the record is because of a live update from another session. The\r\n  client script can then decide what action to take, or not to take. This\r\n  applies to systems using UI16 with live forms enabled.\r\n"]
[0.000, "o", "  g_form.isLiveUpdating();\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop isNewRecord\u001b[0m\r\n\r\n  Returns true if the record has never been saved Returns false if the\r\n  record has been saved\r\n"]
[0.000, "o", "  g_form.isNewRecord();\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop isSectionVisible\u001b[0m\r\n\r\n  Returns true if the section is visible Returns false if the section is\r\n"]
[0.000, "o", "  not visible or does not exist. This method is available starting with\r\n  the Fuji release\r\n  g_form.isSectionVisible('patching');\r\n"]
[0.000, "o", "\r\n\u001b[1mDesktop refreshSlushbucket\u001b[0m\r\n\r\n"]
[0.000, "o", "  You can update a list collector variable.\r\n  g_form.refreshSlushbucket('bucket');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop removeDecoration\u001b[0m\r\n\r\n  Removes the icon from the specified field that matches the icon and\r\n"]
[0.000, "o", "  title. Note: This method is not supported by Service Catalog.\r\n  g_form.removeDecoration('caller_id','fa-star','VIP');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop removeOption\u001b[0m\r\n\r\n  Removes a specific option from a choice list\r\n"]
[0.000, "o", "  g_form.removeOption('priority','1');\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop save\u001b[0m\r\n"]
[0.000, "o", "\r\n  Saves the record without navigating away from the record (update and\r\n"]
[0.000, "o", "  stay)\r\n"]
[0.000, "o", "  g_form.save();\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop setDisabled\u001b[0m\r\n\r\n  Grays out field and makes it unavailable\r\n  var bool = true;\r\n  g_form.setDisabled('caller_id', true);\r\n"]
[0.000, "o", "\r\n\u001b[1mDesktop setDisplay\u001b[0m\r\n"]
[0.000, "o", "\r\n  Displays the field if true. Hides the field if false. This method cannot\r\n  hide mandatory fields with no value. If the field is hidden, the space\r\n  is used to display other items"]
[0.000, "o", "\r\n"]
[0.000, "o", "  var bool = true;\r\n  g_form.setDisplay('caller_id', true);\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop setLabelOf\u001b[0m\r\n\r\n"]
[0.000, "o", "  Sets the plain text value of the field label. This method is available\r\n  starting with the Fuji release\r\n  if (g_user.hasRole('itil')) {\r\n"]
[0.000, "o", "  var oldLabel = g_form.getLabelOf('comments');\r\n  g_form.setLabelOf('comments', oldLabel + ' (Customer visible)');\r\n  }\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop setMandatory\u001b[0m\r\n\r\n"]
[0.000, "o", "  Makes the field required if true. Makes the field optional if false.\r\n  Best Practice: Use UI Policy rather than this method whenever possible\r\n"]
[0.000, "o", "  g_form.setMandatory('quantity',true);// changes field to required or not\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop setReadOnly\u001b[0m\r\n\r\n  Makes the field read-only if true Makes the field editable if false.\r\n"]
[0.000, "o", "  Note: Both setReadOnly and setReadonly are functional. Best Practice:\r\n  Use UI Policy rather than this method whenever possible\r\n  g_form.setValue('milestone', milestone);\r\n  g_form.setReadonly('end_date', milestone);\r\n"]
[0.000, "o", "  g_form.setReadonly('duration', milestone);\r\n"]
[0.000, "o", "\r\n\u001b[1mDesktop setSectionDisplay\u001b[0m\r\n\r\n"]
[0.000, "o", "  Shows or hides a section Works in both tab and flat modes. This method\r\n  is available starting with the Fuji release\r\n  function onChange(control, oldValue, newValue, isLoading) {\r\n"]
[0.000, "o", "  //this example was run on a form divided into sections (Change form)\r\n  // and hid a section when the \"state\" field was changed\r\n  var sections = g_form.getSections();\r\n"]
[0.000, "o", "  if (newValue == '2') {\r\n  g_form.setSectionDisplay(sections[1], false);\r\n"]
[0.000, "o", "  } else {\r\n"]
[0.000, "o", "  g_form.setSectionDisplay(sections[1], true);\r\n  }\r\n"]
[0.000, "o", "  }\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop setValue\u001b[0m\r\n\r\n"]
[0.000, "o", "  Sets the value and the display value of a field Will display value if\r\n"]
[0.000, "o", "  there is no displayValue\r\n  g_form.setValue('quantity','10');// sets the value to 10\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop setVisible\u001b[0m\r\n\r\n"]
[0.000, "o", "  Displays the field if true. Hides the field if false. If the field is\r\n  hidden, the space is left blank. This method cannot hide mandatory\r\n"]
[0.000, "o", "  fields with no value\r\n  function onLoad() {\r\n  g_form.setVisible('u_environment', false);\r\n  }\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mDesktop showErrorBox\u001b[0m\r\n\r\n"]
[0.000, "o", "  Displays an error message under the specified form field (either a\r\n"]
[0.000, "o", "  control object or the name of the field). If the control or field is\r\n  currently scrolled off the screen, it will be scrolled to. A global\r\n"]
[0.000, "o", "  property (glide.ui.scroll\\_to\\_message\\_field) is available that\r\n  controls automatic message scrolling when the form field is offscreen\r\n"]
[0.000, "o", "  (scrolls the form to the control or field). The showFieldMsg() method is\r\n  a similar method that requires a 'type' parameter\r\n"]
[0.000, "o", "  var scroll = true;\r\n  g_form.showErrorBox('caller_id','message',scroll)\r\n\r\n\u001b[1mDesktop showFieldMsg\u001b[0m\r\n"]
[0.000, "o", "\r\n  Displays either an informational or error message under the specified\r\n"]
[0.000, "o", "  form field (either a control object or the name of the field). Type may\r\n  be either 'info' or 'error.' If the control or field is currently\r\n  scrolled off the screen, it will be scrolled to. A global property\r\n"]
[0.000, "o", "  (glide.ui.scroll\\_to\\_message\\_field) is available that controls\r\n"]
[0.000, "o", "  automatic message scrolling when the form field is offscreen (scrolls\r\n"]
[0.000, "o", "  the form to the control or field)\r\n  // parameters are;\r\n"]
[0.000, "o", "  // field, string, info||error, scrollToField\r\n"]
[0.000, "o", "  g_form.showFieldMsg('stage', 'text info', 'info', false);\r\n"]
[0.000, "o", "  g_form.showFieldMsg('stage', 'text erro', 'error', false);\r\n\r\n"]
[0.000, "o", "\u001b[1mDesktop showRelatedList\u001b[0m\r\n\r\n  Displays the specified related list on the form\r\n  function onChange(control, oldValue, newValue, isLoading, isTemplate) {\r\n"]
[0.000, "o", "  if (isLoading || newValue === '') {\r\n  return;\r\n"]
[0.000, "o", "  }\r\n"]
[0.000, "o", "  if(newValue == 'hide'){\r\n  g_form.hideRelatedList('sc_request');\r\n"]
[0.000, "o", "  } else if(newValue == 'show') {\r\n  g_form.showRelatedList('sc_request');\r\n"]
[0.000, "o", "  } else if(newValue == 'hide all'){\r\n"]
[0.000, "o", "  g_form.hideRelatedLists();\r\n  } else if(newValue == 'show all'){\r\n"]
[0.000, "o", "  g_form.showRelatedLists();\r\n  }\r\n  }"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\n"]
