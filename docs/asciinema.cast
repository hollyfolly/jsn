[0.926, "o", "\u001b[3;90m# Use `jsn updateset use` or `jsn scope use` to change scope/updateset\u001b[0m\r\n\u001b[1;90mPROFILE USER   [SCOPE]  UPDATE SET\u001b[0m\r\n\u001b]8;;https://dev373698.service-now.com\u001b\\pdi    \u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_user_list.do?sysparm_query=sys_id=6816f79cc0a8016401c5a33be04be441\u001b\\System\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_scope.do?sysparm_query=scope=global\u001b\\[global]\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_update_set.do?sys_id=7dba58ecf54403100a22c0b3dfa151af\u001b\\Default\u001b]8;;\u001b\\\r\n"]
[0.095, "o", "\r\n\u001b[1;38;2;232;162;23mAIAB Chat (aiab_chat)\u001b[0m\r\n\r\n\u001b[1;38;2;102;102;102m─ Basic Information ─\u001b[0m\r\n  \u001b[38;2;136;136;136mName:\u001b[0m  AIAB Chat\r\n  \u001b[38;2;136;136;136mID:\u001b[0m  aiab_chat\r\n  \u001b[38;2;136;136;136mScope:\u001b[0m  AI in a Box\r\n"]
[0.000, "o", "  \u001b[38;2;136;136;136mDescription:\u001b[0m  AI In A Box floating chat widget with real-time streaming responses. Customizable via CSS variables.\r\n\r\n  \u001b[38;2;136;136;136mWidget URL:\u001b[0m  \u001b]8;;https://dev373698.service-now.com/sp_widget.do?sys_id=3e72f39a83a2b2104d4fccb6feaad33d\u001b\\https://dev373698.service-now.com/sp_widget.do?sys_id=3e72f39a83a2b2104d4fccb6feaad33d\u001b]8;;\u001b\\\r\n\r\n─────\r\n\r\n"]
[0.000, "o", "\u001b[1;38;2;232;162;23mHints:\u001b[0m\r\n  jsn sp-widgets --search <term>                      \u001b[38;2;136;136;136mSearch widgets\u001b[0m\r\n  jsn sp-widgets show aiab_chat --html                \u001b[38;2;136;136;136mShow HTML template\u001b[0m\r\n  jsn sp-widgets show aiab_chat --css                 \u001b[38;2;136;136;136mShow CSS\u001b[0m\r\n  jsn sp-widgets show aiab_chat --client              \u001b[38;2;136;136;136mShow client script\u001b[0m\r\n  jsn sp-widgets show aiab_chat --server              \u001b[38;2;136;136;136mShow server script\u001b[0m\r\n  jsn sp-widgets show aiab_chat --html --css --client --server  \u001b[38;2;136;136;136mShow all code\u001b[0m\r\n\r\n"]
