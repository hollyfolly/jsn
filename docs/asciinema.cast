[0.418, "o", "\r\n\u001b[1;38;2;232;162;23mINC0000050 (incident)\u001b[0m\r\n\r\n\r\n\u001b[1;38;2;102;102;102m─ Core ─\u001b[0m\r\n  \u001b[38;2;136;136;136mnumber:\u001b[0m  INC0000050\r\n  \u001b[38;2;136;136;136msys_id:\u001b[0m  ef43c6d40a0a0b5700c77f9bf387afe3\r\n  \u001b[38;2;136;136;136msys_class_name:\u001b[0m  Incident\r\n  \u001b[38;2;136;136;136mstate:\u001b[0m  In Progress\r\n  \u001b[38;2;136;136;136mactive:\u001b[0m  true\r\n  \u001b[38;2;136;136;136mshort_description:\u001b[0m  Can't access Exchange server - is it down?\r\n  \u001b[38;2;136;136;136mdescription:\u001b[0m  Can't connect to Exchange. Login credentials and network connection are working though.\r\n  \u001b[38;2;136;136;136mpriority:\u001b[0m  1 - Critical\r\n  \u001b[38;2;136;136;136murgency:\u001b[0m  1 - High\r\n  \u001b[38;2;136;136;136mimpact:\u001b[0m  1 - High\r\n\r\n\u001b[1;38;2;102;102;102m─ People ─\u001b[0m\r\n  \u001b[38;2;136;136;136mopened_by:\u001b[0m  \r\n  \u001b[38;2;136;136;136massigned_to:\u001b[0m  Beth Anglin\r\n  \u001b[38;2;136;136;136massignment_group:\u001b[0m  Hardware\r\n  \u001b[38;2;136;136;136mclosed_by:\u001b[0m  \r\n  \u001b[38;2;136;136;136mresolved_by:\u001b[0m  \r\n  \u001b[38;2;136;136;136mcaller_id:\u001b[0m  Jerrod Bennett\r\n\r\n\u001b[1;38;2;102;102;102m─ Request Info ─\u001b[0m\r\n  \u001b[38;2;136;136;136mcmdb_ci:\u001b[0m  EXCH-SD-05\r\n  \u001b[38;2;136;136;136mbusiness_service:\u001b[0m  \r\n\r\n\u001b[1;38;2;102;102;102m─ Dates & Times ─\u001b[0m\r\n  \u001b[38;2;136;136;136mopened_at:\u001b[0m  2026-03-10 14:58:24\r\n  \u001b[38;2;136;136;136msys_created_on:\u001b[0m  2026-03-10 11:05:40\r\n  \u001b[38;2;136;136;136msys_updated_on:\u001b[0m  2026-03-31 12:49:40\r\n  \u001b[38;2;136;136;136mclosed_at:\u001b[0m  \r\n  \u001b[38;2;136;136;136mresolved_at:\u001b[0m  \r\n  \u001b[38;2;136;136;136mwork_start:\u001b[0m  \r\n  \u001b[38;2;136;136;136mwork_end:\u001b[0m  \r\n  \u001b[38;2;136;136;136mdue_date:\u001b[0m  \r\n  \u001b[38;2;136;136;136