[0.317, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[133D\u001b[2K\u001b[1;38;2;232;162;23mSelect a record from incident:\u001b[0m\r\r\n\r\r\n\u001b[38;2;232;162;23m> \u001b[0m\u001b[1mINC0000050\u001b[0m\u001b[38;2;136;136;136m - Can't access Exchange server - is it down?\u001b[0m\r\r\n  INC0000001\u001b[38;2;136;136;136m - Can't read email\u001b[0m\r\r\n  INC0000005\u001b[38;2;136;136;136m - CPU load high for over 10 minutes\u001b[0m\r\r\n  INC0000034\u001b[38;2;136;136;136m - Does not look like a backup occurred last night\u001b[0m\r\r\n  INC0000013\u001b[38;2;136;136;136m - EMAIL is slow when an attachment is involved\u001b[0m\r\r\n  INC0009005\u001b[38;2;136;136;136m - Email server is down.\u001b[0m\r\r\n  INC0007001\u001b[38;2;136;136;136m - Employee payroll application server is down.\u001b[0m\r\r\n  INC0000033\u001b[38;2;136;136;136m - File Server is 80% full - Needs upgrade\u001b[0m\r\r\n  INC0000004\u001b[38;2;136;136;136m - Forgot email password\u001b[0m\r\r\n  INC0000006\u001b[38;2;136;136;136m - Hangs when trying to print VISIO document\u001b[0m\r\r\n  INC0000017\u001b[38;2;136;136;136m - How do I create a sub-folder\u001b[0m\r\r\n  INC0000015\u001b[38;2;136;136;136m - I can't launch my VPN client since the last software update\u001b[0m\r\r\n  INC0000051\u001b[38;2;136;136;136m - Manager can't access SAP Controlling application\u001b[0m\r\r\n  INC0000014\u001b[38;2;136;136;136m - Missing my home directory\u001b[0m\r\r\n  INC0000007\u001b[38;2;136;136;136m - Need access to sales DB for the West\u001b[0m\r\r\n\r\r\n\u001b[38;2;136;136;136m1-15 of 27 loaded\u001b[0m\r\r\n\u001b[38;2;136;136;136m↑/↓ navigate • enter select • esc cancel • /search • a-z jump\u001b[0m\r\r\n\u001b[133D"]
