[0.000, "o", "\u001b[1mExamples\u001b[0m\r\n\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0mvar gr = new GlideRecord('incident');\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0mgr.addQuery('priority', '<=', 2);\u001b[0m\r\n    \u001b[38;2;0;255;0mgr.addQuery('state', 'IN', '1,2');\u001b[0m\r\n    \u001b[38;2;0;255;0mgr.query();\u001b[0m\r\n\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0mnew GlideQuery('incident')\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0m  .where('priority', '<=', 2)\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0m  .where('state', 'IN', [1, 2])\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0m  .select();\u001b[0m\r\n\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0mvar ga = new GlideAggregate('incident');\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0mga.addQuery('priority', '<=', 2);\u001b[0m\r\n    \u001b[38;2;0;255;0mga.addAggregate('COUNT');\u001b[0m\r\n"]
[0.000, "o", "    \u001b[38;2;0;255;0mga.query();\u001b[0m\r\n"]
