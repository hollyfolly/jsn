[1.295, "o", "\u001b[3;90m# Use `jsn updateset use` or `jsn scope use` to change scope/updateset\u001b[0m\r\n\u001b[1;90mPROFILE USER   [SCOPE]  UPDATE SET\u001b[0m\r\n\u001b]8;;https://dev373698.service-now.com\u001b\\pdi    \u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_user_list.do?sysparm_query=sys_id=6816f79cc0a8016401c5a33be04be441\u001b\\System\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_scope.do?sysparm_query=scope=global\u001b\\[global]\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_update_set.do?sys_id=7dba58ecf54403100a22c0b3dfa151af\u001b\\Default\u001b]8;;\u001b\\\r\n\r\n\u001b[1;38;2;232;162;23mAvailable Documentation Topics\u001b[0m\r\n\r\n  \u001b[1;38;2;232;162;23mAPI Reference\u001b[0m\r\n    • \u001b[38;2;136;136;136mgliderecord\u001b[0m\r\n    • \u001b[38;2;136;136;136mglidequery\u001b[0m\r\n    • \u001b[38;2;136;136;136mglideaggregate\u001b[0m\r\n    • \u001b[38;2;136;136;136mgliderecordsecure\u001b[0m\r\n\r\n  \u001b[1;38;2;232;162;23mQuery\u001b[0m\r\n    • \u001b[38;2;136;136;136moperators\u001b[0m\r\n\r\n  \u001b[1;38;2;232;162;23mClient-side\u001b[0m\r\n    • \u001b[38;2;136;136;136mglideform\u001b[0m\r\n    • \u001b[38;2;136;136;136mglideuser\u001b[0m\r\n    • \u001b[38;2;136;136;136mglideajax\u001b[0m\r\n\r\n  \u001b[1;38;2;232;162;23mServer-side\u001b[0m\r\n"]
[0.000, "o", "    • \u001b[38;2;136;136;136mglidesystem\u001b[0m\r\n    • \u001b[38;2;136;136;136mglideelement\u001b[0m\r\n    • \u001b[38;2;136;136;136mglidedatetime\u001b[0m\r\n\r\n  \u001b[1;38;2;232;162;23mREST APIs\u001b[0m\r\n    • \u001b[38;2;136;136;136mrestmessagev2\u001b[0m\r\n    • \u001b[38;2;136;136;136mrestapirequest\u001b[0m\r\n    • \u001b[38;2;136;136;136mrestapiresponse\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[38;2;136;136;136mUse 'jsn docs <topic>' to view documentation\u001b[0m\r\n\r\n"]
