[1.117, "o", "\u001b[3;90m# Use `jsn updateset use` or `jsn scope use` to change scope/updateset\u001b[0m\r\n\u001b[1;90mPROFILE USER   [SCOPE]  UPDATE SET\u001b[0m\r\n\u001b]8;;https://dev373698.service-now.com\u001b\\pdi    \u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_user_list.do?sysparm_query=sys_id=6816f79cc0a8016401c5a33be04be441\u001b\\System\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_scope.do?sysparm_query=scope=global\u001b\\[global]\u001b]8;;\u001b\\ \u001b]8;;https://dev373698.service-now.com/sys_update_set.do?sys_id=7dba58ecf54403100a22c0b3dfa151af\u001b\\Default\u001b]8;;\u001b\\\r\n\u001b[1mExplore\u001b[0m\r\n  tables           List and inspect tables (sys_db_object, sys_dictionary)                                \u001b[38;2;136;136;136mlist, show, schema, columns, relationships, dependencies, diagram\u001b[0m\r\n  rules            Business rules (sys_script) — server-side scripts on table operations                  \u001b[38;2;136;136;136mscript\u001b[0m\r\n  flows            Flow Designer flows (sys_hub_flow)                                                     \u001b[38;2;136;136;136mcreate, executions, execute, debug, variables, activate, deactivate\u001b[0m\r\n  jobs             Scheduled jobs (sysauto_script, sys_trigger)                                           \u001b[38;2;136;136;136mexecutions, logs, run, script\u001b[0m\r\n  script-includes  Script includes (sys_script_include) — reusable server-side classes/functions          \u001b[38;2;136;136;136mscript\u001b[0m\r\n  ui-policies      UI policies (sys_ui_policy) — form field visibility/mandatory/readonly rules           \u001b[38;2;136;136;136mscript\u001b[0m\r\n  client-scripts   Client scripts (sys_script_client) — browser-side form scripts                         \u001b[38;2;136;136;136mscript\u001b[0m\r\n  acls             Access control lists (sys_security_acl) — row/field-level security                     \u001b[38;2;136;136;136mscript, check\u001b[0m\r\n  sp               Service Portals (sp_portal)                                                          \r\n  sp-widgets       Service Portal widgets (sp_widget)                                                     \u001b[38;2;136;136;136mshow\u001b[0m\r\n  sp-pages         Service Portal pages (sp_page) with widget instances                                 \r\n  forms            UI form layouts (sys_ui_section, sys_ui_element)                                     \r\n  lists            UI list column layouts (sys_ui_list, sys_ui_list_element)                            \r\n  ui-scripts       UI scripts (sys_ui_script) — global client-side includes                               \u001b[38;2;136;136;136mscript\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[1mData\u001b[0m\r\n  records          CRUD on any table via Table API — the generic workhorse                                \u001b[38;2;136;136;136mcreate, update, delete\u001b[0m\r\n  choices          Choice values (sys_choice) — dropdown options for table fields                         \u001b[38;2;136;136;136mlist, create, update, delete, reorder\u001b[0m\r\n\r\n\u001b[1mService Catalog\u001b[0m\r\n"]
[0.000, "o", "  catalog-item     Service Catalog items (sc_cat_item) with variables                                     \u001b[38;2;136;136;136mcreate, create-variable, variables\u001b[0m\r\n  variable         Catalog item variables (item_option_new) and their dropdown choices (question_choice)  \u001b[38;2;136;136;136mshow, choices, add-choice, remove-choice\u001b[0m\r\n  variable-types   Reference list of all catalog variable types (static data)                           \r\n\r\n\u001b[1mDevelopment\u001b[0m\r\n  updateset        Update sets (sys_update_set) — track and transport changes                             \u001b[38;2;136;136;136mlist, show, use, create, parent\u001b[0m\r\n"]
[0.000, "o", "  scope            Application scopes (sys_scope) — namespace isolation for apps                          \u001b[38;2;136;136;136mshow, list, use\u001b[0m\r\n  rest             Raw REST API calls — escape hatch for any endpoint                                     \u001b[38;2;136;136;136mget, post, patch, delete\u001b[0m\r\n  eval             Run background scripts (Scripts - Background) — server-side JS execution             \r\n\r\n"]
[0.000, "o", "\u001b[1mDebugging\u001b[0m\r\n  logs             System logs (syslog) — recent errors, warnings, debug output                         \r\n"]
[0.000, "o", "  instance         Instance connection and version info                                                   \u001b[38;2;136;136;136minfo\u001b[0m\r\n"]
[0.000, "o", "  docs             Offline documentation and reference                                                    \u001b[38;2;136;136;136mlist, search, update\u001b[0m\r\n\r\n\u001b[1mConfiguration\u001b[0m\r\n  config           Manage instance profiles                                                               \u001b[38;2;136;136;136madd, switch, list, get\u001b[0m\r\n"]
[0.001, "o", "  auth             Authentication — login, logout, status check                                           \u001b[38;2;136;136;136mlogin, logout, status\u001b[0m\r\n"]
[0.000, "o", "  setup            Interactive first-time setup wizard                                                  \r\n\r\n"]
[0.000, "o", "\u001b[1mSystem\u001b[0m\r\n  commands         List all commands with descriptions and hints                                        \r\n  version          Show version information                                                             \r\n"]
[0.000, "o", "  help             Show help for any command                                                            \r\n"]
