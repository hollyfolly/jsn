[0.002, "o", "\u001b[32m◆\u001b[39m  \u001b[1mWhich agents do you want to install to?\u001b[22m\r\n\u001b[2m│\u001b[22m\r\n\u001b[2m│\u001b[22m  \u001b[2m─\u001b[22m\u001b[2m─\u001b[22m \u001b[1mUniversal (.agents/skills)\u001b[22m \u001b[2m── always included\u001b[22m \u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mAmp\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mAntigravity\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mCline\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mCodex\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mCursor\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mDeep Agents\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mFirebender\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mGemini CLI\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mGitHub Copilot\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mKimi Code CLI\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mOpenCode\u001b[22m\r\n\u001b[2m│\u001b[22m    \u001b[32m•\u001b[39m \u001b[1mWarp\u001b[22m\r\n\u001b[2m│\u001b[22m\r\n\u001b[2m│\u001b[22m  \u001b[2m─\u001b[22m\u001b[2m─\u001b[22m \u001b[1mAdditional agents\u001b[22m \u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\u001b[2m─\u001b[22m\r\n\u001b[2m│\u001b[22m  \u001b[2mSearch:\u001b[22m \u001b[7m \u001b[27m\r\n\u001b[2m│\u001b[22m  \u001b[2m↑↓ move, space select, enter confirm\u001b[22m\r\n\u001b[2m│\u001b[22m\r\n\u001b[2m│\u001b[22m \u001b[36m❯\u001b[39m \u001b[2m○\u001b[22m \u001b[4mAugment\u001b[24m\u001b[2m (.augment/skills)\u001b[22m\r\n\u001b[2m│\u001b[22m   \u001b[2m○\u001b[22m IBM Bob\u001b[2m (.bob/skills)\u001b[22m\r\n\u001b[2m│\u001b[22m   \u001b[2m○\u001b[22m Claude Code\u001b[2m (.claude/skills)\u001b[22m\r\n\u001b[2m│\u001b[22m   \u001b[2m○\u001b[22m OpenClaw\u001b[2m (skills)\u001b[22m\r\n\u001b[2m│\u001b[22m   \u001b[2m○\u001b[22m CodeBuddy\u001b[2m (.codebuddy/skills)\u001b[22m\r\n\u001b[2m│\u001b[22m   \u001b[2m○\u001b[22m Command Code\u001b[2m (.commandcode/skills)\u001b[22m\r\n\u001b[2m│\u001b[22m   \u001b[2m○\u001b[22m Continue\u001b[2m (.continue/skills)\u001b[22m\r\n\u001b[2m│\u001b[22m   \u001b[2m○\u001b[22m Cortex Code\u001b[2m (.cortex/skills)\u001b[22m\r\n\u001b[2m│\u001b[22m  \u001b[2m↓ 23 more\u001b[22m\r\n\u001b[2m│\u001b[22m\r\n\u001b[2m│\u001b[22m  \u001b[32mSelected:\u001b[39m Amp, Antigravity, Cline +9 more\r\n\u001b[2m└\u001b[22m\r\n"]
